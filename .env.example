```ini

# ===========================

# BEHIND THE CHAPTER ENGINE

# Environment Configuration

# ===========================



# --- LLM Providers ---

OPENAI_API_KEY=sk-...

OPENAI_MODEL=gpt-4o

OPENAI_TEMPERATURE=0.2



ANTHROPIC_API_KEY=sk-ant-...

ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

ANTHROPIC_TEMPERATURE=0.1



# Fallback strategy: openai → anthropic → local

LLM_FALLBACK_ENABLED=true

LLM_FALLBACK_ORDER=openai,anthropic



# --- Vector Memory (Pinecone) ---

PINECONE_API_KEY=pc-...

PINECONE_INDEX=behind-the-chapter

PINECONE_ENVIRONMENT=us-east1-gcp

PINECONE_DIMENSION=3072



# Alternative: Weaviate

# WEAVIATE_URL=http://localhost:8080

# WEAVIATE_API_KEY=...



# --- Queue & Orchestration ---

REDIS_URL=redis://localhost:6379

QUEUE_CONCURRENCY=5

QUEUE_RETRIES=3

PIPELINE_TIMEOUT_MS=1800000



# --- Publishing ---

WORDPRESS_URL=https://your-site.com

WORDPRESS_USERNAME=editor

WORDPRESS_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

WORDPRESS_DEFAULT_CATEGORY=Insights

WORDPRESS_PUBLISH_STATUS=publish # or ‘draft’ for human review



# --- Cognitive Parameters ---

MIN_NOVELTY_SCORE=6.0

MIN_DEPTH_SCORE=7.0

CONSENSUS_THRESHOLD=0.75

MAX_DEBATE_ROUNDS=3

BELIEF_CONFIDENCE_PUBLISH_MIN=0.75



# Autonomous Topic Generation

TOPIC_GEN_STRATEGIES=gap,depth,contrarian,synthesis

TOPIC_GEN_BATCH_SIZE=10

TOPIC_GEN_MIN_COMPOSITE_SCORE=6.5



# --- Logging & Monitoring ---

LOG_LEVEL=info

LOG_FILE=output/logs/combined.log

SENTRY_DSN=https://...@sentry.io/...

PROMETHEUS_PORT=9090



# --- Security ---

BTC_WEBHOOK_TOKEN=your-secure-webhook-token

API_RATE_LIMIT_WINDOW_MS=900000

API_RATE_LIMIT_MAX=10



# --- Development ---

NODE_ENV=production

DEBUG_AGENTS=false

DRY_RUN=false

LOCAL_MEMORY_ONLY=false



# --- Optional: Local LLM (Ollama) ---

OLLAMA_BASE_URL=http://localhost:11434

OLLAMA_MODEL=mistral-large

```
